# =============================================================================
# WorkPilot — environment template
# Copy to .env  (or run ./setup.sh / .\setup.ps1)
# Never commit real .env / secrets.
# =============================================================================

# —— Database (required) ——
# Local Docker (default from setup.sh):
DATABASE_URL="postgresql://workpilot:workpilot@localhost:5432/workpilot?schema=public"
DIRECT_URL="postgresql://workpilot:workpilot@localhost:5432/workpilot?schema=public"

# Supabase example (replace password + project ref):
# DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require"
# DIRECT_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# —— Auth (required) ——
# setup.sh generates BETTER_AUTH_SECRET automatically
BETTER_AUTH_SECRET="generate-a-random-32-char-secret"
BETTER_AUTH_URL="http://localhost:3000"

# —— Redis (local Docker) ——
REDIS_URL="redis://localhost:6379"

# —— Email (Resend) — optional in local dev ——
RESEND_API_KEY=""
EMAIL_FROM="noreply@yourdomain.com"

# —— WhatsApp (Twilio) — optional ——
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_WHATSAPP_FROM=""

# —— Push (Firebase Cloud Messaging) — optional ——
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
NEXT_PUBLIC_FIREBASE_VAPID_KEY=""

# —— Storage (R2 / S3) — optional; local uploads if empty ——
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""
S3_ENDPOINT=""
S3_REGION="auto"
UPLOAD_DIR="uploads"

# —— App ——
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_ROOT_DOMAIN="localhost:3000"

# —— Platform operator console (/platform) — comma-separated emails ——
PLATFORM_ADMIN_EMAILS="you@example.com"
